{
  "name": "@omnidotdev/messaging",
  "version": "0.1.0",
  "description": "Shared, transport-agnostic 1:1 messaging core for the Omni ecosystem. App-specific authorization, moderation, monetization, encryption, and delivery are injected, so the core stays neutral across SFW and adult, centralized and federated.",
  "license": "Apache-2.0",
  "type": "module",
  "main": "./build/index.js",
  "module": "./build/index.js",
  "types": "./build/index.d.ts",
  "exports": {
    ".": {
      "import": "./build/index.js",
      "types": "./build/index.d.ts"
    },
    "./schema": {
      "import": "./build/schema.js",
      "types": "./build/schema.d.ts"
    }
  },
  "files": ["build"],
  "scripts": {
    "build": "bun build ./src/index.ts ./src/schema.ts --outdir ./build --target node && tsc",
    "prepare": "bun run build",
    "test": "bun test src",
    "check": "biome check src"
  },
  "peerDependencies": {
    "drizzle-orm": "*"
  },
  "peerDependenciesMeta": {
    "drizzle-orm": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/bun": "latest",
    "drizzle-orm": "^0.44.0",
    "typescript": "^5"
  }
}
